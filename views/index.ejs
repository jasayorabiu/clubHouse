<html>

<head>
  <title>Clubhouse</title>
  <%- include('partials/styles.ejs') %>

</head>

<body>

  <%= error ? `<p>${error}</p>` : '' %>
  <%- include('partials/header.ejs') %>
  <h2>Messages </h2>
  <p>Welcome <%= user ? user.firstname : 'Guest' %></p>

  <% if (user?.firstname) {     %>

  <div>
    <% if (user?.membership_status ) { %>
    <p>Your membership status: <%= user?.membership_status %></p>
    <% } else { %>
    <form action="/auth/activate-membership" method="POST">
      <input type="text" name="code" required placeholder="Enter secret code">
      <button type="submit">Activate Membership</button>
    </form>
    <% } %>
  </div>

  <%}%>
  <div class="compose-box">
    <form action="/messages/<%= user ? '' : 'anon' %>" method="POST">
      <input type="text" name="title" placeholder="Title" required>
      <textarea name="content" placeholder="What's on your mind?" required></textarea>
      <button type="submit">Post Message</button>
    </form>
  </div>

  <% if (messages && messages.length > 0) { %>
  <ul>
    <% messages.forEach(message => { %>
    <li>
      <p><%= message.content %></p>
      <p>Posted by: <%= Boolean(user?.membership_status) ? message?.firstname : 'Anonymous' %></p>
      <p> Posted at: <%= Boolean(user?.membership_status) ? message.created_at : 'Anonymous' %></p>
      <% if (user &&  user.admin) { %>
      <form action="/messages/<%= message.id %>/delete" method="POST">
        <button type="submit">Delete</button>
      </form>
      <% } %>
    </li>
    <% }) %>
  </ul>
  <% } %>

</body>

</html>